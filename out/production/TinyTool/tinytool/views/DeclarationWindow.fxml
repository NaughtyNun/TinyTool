<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="280.0" prefWidth="450.0"
            xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tinytool.controllers.DeclarationWindowController">
   <children>
      <Label layoutX="14.0" layoutY="30.0" text="Dates worked from home" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="30.0" />
      <DatePicker fx:id="datePicker" layoutX="183.0" layoutY="26.0" promptText="remote access days" AnchorPane.leftAnchor="180.0" AnchorPane.topAnchor="25.0" />
      <Button fx:id="btnAdd" layoutX="384.0" layoutY="26.0" mnemonicParsing="false" onAction="#handleAdd" text="Add Day" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="25.0" />
      <ListView fx:id="listDates" layoutX="14.0" layoutY="62.0" prefHeight="140.0" prefWidth="345.0" AnchorPane.leftAnchor="10.0" />
      <Label fx:id="fileString" layoutX="14.0" layoutY="199.0" text="Label" textFill="#0011ff" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="210.0">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Label>
      <ButtonBar layoutX="392.0" layoutY="346.0" prefHeight="40.0" prefWidth="200.0" AnchorPane.bottomAnchor="5.0" AnchorPane.rightAnchor="5.0">
        <buttons>
          <Button fx:id="btnCreate" mnemonicParsing="false" onAction="#handleCreate" text="Create" />
            <Button fx:id="btnCopy" mnemonicParsing="false" onAction="#handleCopy" text="Copy" />
            <Button mnemonicParsing="false" onAction="#handleExit" text="Exit" />
        </buttons>
      </ButtonBar>
   </children>
</AnchorPane>
